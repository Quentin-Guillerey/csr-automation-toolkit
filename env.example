# CSR Automation Toolkit — Environment Configuration Template
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to version control

# Slack Webhook URL (for real-time alerts)
# Get from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Gmail Configuration (for email auto-reply)
# Use an app-specific password, not your regular Gmail password
# https://support.google.com/accounts/answer/185833
EMAIL_ADDRESS=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Google Sheets Configuration (for audit logging)
# Get the Sheet ID from the URL: docs.google.com/spreadsheets/d/{SHEET_ID}
GSHEETS_ID=your-google-sheet-id-here

# Google Sheets Service Account Credentials (JSON key)
# Create at https://console.cloud.google.com/
# Copy the entire JSON as a single line (use an online JSON minifier if needed)
GSHEETS_CREDENTIALS={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# OpenAI API Key (optional, for LLM-based query classification)
# If not provided, toolkit falls back to keyword matching
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
